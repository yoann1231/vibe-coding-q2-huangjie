{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Skill F Report Generator Input",
  "type": "object",
  "required": [
    "product",
    "marketing",
    "profit"
  ],
  "properties": {
    "product": {
      "type": "object",
      "required": [
        "index",
        "name_cn",
        "keyword_en"
      ],
      "properties": {
        "index": {
          "type": "integer",
          "minimum": 1
        },
        "name_cn": {
          "type": "string",
          "minLength": 1
        },
        "keyword_en": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "marketing": {
      "type": "object",
      "required": [
        "amazon_heat",
        "blue_ocean_competition",
        "safety_compliance",
        "factory_instruction"
      ],
      "properties": {
        "amazon_heat": {
          "type": "string",
          "minLength": 1
        },
        "blue_ocean_competition": {
          "type": "string",
          "minLength": 1
        },
        "safety_compliance": {
          "type": "string",
          "minLength": 1
        },
        "factory_instruction": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "profit": {
      "type": "object",
      "required": [
        "decision",
        "metrics"
      ],
      "properties": {
        "decision": {
          "type": "string",
          "enum": [
            "GO",
            "PASS"
          ]
        },
        "metrics": {
          "type": "object",
          "required": [
            "temu_king_price_usd",
            "income_estimate_usd",
            "income_estimate_cny",
            "cost_1688_cny",
            "fulfillment_fee_cny",
            "total_cost_cny",
            "net_profit_cny"
          ],
          "properties": {
            "temu_king_price_usd": {
              "type": "number"
            },
            "income_estimate_usd": {
              "type": "number"
            },
            "income_estimate_cny": {
              "type": "number"
            },
            "cost_1688_cny": {
              "type": "number"
            },
            "fulfillment_fee_cny": {
              "type": "number"
            },
            "total_cost_cny": {
              "type": "number"
            },
            "net_profit_cny": {
              "type": "number"
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
